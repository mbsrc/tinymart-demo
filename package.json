{
  "name": "tinymart",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "start": "node dist/server.js",
    "lint": "biome check --write .",
    "format": "biome check --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run tests/e2e/",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:dev:create": "docker exec tinymart-db psql -U tinymart -d postgres -c 'CREATE DATABASE tinymart_dev OWNER tinymart' || true",
    "db:test:create": "docker exec tinymart-db psql -U tinymart -d postgres -c 'CREATE DATABASE tinymart_test OWNER tinymart' || true",
    "db:migrate": "tsx node_modules/.bin/sequelize-cli db:migrate",
    "db:migrate:undo": "tsx node_modules/.bin/sequelize-cli db:migrate:undo",
    "db:seed": "tsx node_modules/.bin/sequelize-cli db:seed:all",
    "load-test": "k6 run load-tests/smoke.js"
  },
  "dependencies": {
    "@logtail/node": "^0.5.2",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "pg": "^8.13.3",
    "pg-boss": "^12.14.0",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.5",
    "stripe": "^17.5.0",
    "tsx": "^4.19.2",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/express": "^5.0.0",
    "@types/node": "^22.12.0",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "sequelize-cli": "^6.6.2",
    "supertest": "^7.0.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
