{
  "name": "tinymart",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n api,ui \"tsx watch src/server.ts\" \"cd client && bunx vite\"",
    "dev:api": "tsx watch src/server.ts",
    "dev:ui": "cd client && bunx vite",
    "build": "tsc && cd client && bunx vite build",
    "typecheck": "tsc --noEmit && cd client && bunx tsc --noEmit",
    "start": "node dist/server.js",
    "lint": "biome check --write .",
    "format": "biome check --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "cd client && bunx vitest run",
    "test:ui:watch": "cd client && bunx vitest",
    "test:e2e": "vitest run tests/e2e/",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:dev:create": "docker exec tinymart-db psql -U tinymart -d postgres -c 'CREATE DATABASE tinymart_dev OWNER tinymart' || true",
    "db:test:create": "docker exec tinymart-db psql -U tinymart -d postgres -c 'CREATE DATABASE tinymart_test OWNER tinymart' || true",
    "db:migrate": "tsx node_modules/.bin/sequelize-cli db:migrate",
    "db:migrate:undo": "tsx node_modules/.bin/sequelize-cli db:migrate:undo",
    "db:seed": "tsx node_modules/.bin/sequelize-cli db:seed:all",
    "load-test": "k6 run load-tests/smoke.js"
  },
  "dependencies": {
    "@logtail/node": "^0.5.2",
    "@tanstack/react-query": "^5.95.2",
    "cors": "^2.8.6",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "helmet": "^8.1.0",
    "pg": "^8.13.3",
    "pg-boss": "^12.14.0",
    "pg-hstore": "^2.3.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.2",
    "sequelize": "^6.37.5",
    "sequelize-cli": "^6.6.2",
    "stripe": "^17.5.0",
    "tsx": "^4.19.2",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-query-devtools": "^5.95.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.0",
    "@types/node": "^22.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "jsdom": "^29.0.1",
    "msw": "^2.12.14",
    "supertest": "^7.0.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.7.3",
    "vite": "^8.0.2",
    "vitest": "^3.0.5"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
